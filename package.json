{
  "name": "hikayat-daily-ui",
  "version": "0.1.0",
  "description": "A React Native UI component library with design tokens, theming, and glassmorphism support.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "dev": "bob build --watch",
    "typescript": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ui",
    "design-system",
    "components",
    "glassmorphism",
    "theming",
    "dark-mode",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syedmhdarif/hikayat-daily-ui.git"
  },
  "author": "syedmhdarif",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/syedmhdarif/hikayat-daily-ui/issues"
  },
  "homepage": "https://github.com/syedmhdarif/hikayat-daily-ui#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.0",
    "@types/react": "^19.2.14",
    "del-cli": "^6.0.0",
    "eslint": "^8.57.0",
    "react": "^19.0.0",
    "react-native": "^0.81.0",
    "react-native-builder-bob": "^0.35.0",
    "react-native-linear-gradient": "^2.8.0",
    "react-native-svg": "^15.0.0",
    "release-it": "^18.0.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-linear-gradient": ">=2.8.0",
    "react-native-svg": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-linear-gradient": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
